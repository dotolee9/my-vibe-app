# =============================================
# .cursorignore — Cursor AI 인덱싱 제외 목록
# =============================================
# 의존성
node_modules/
**/node_modules/
# 빌드 산출물
.next/
**/out/
**/build/
**/dist/
**/.expo/
# Turbo 캐시
.turbo/
**/.turbo/
# 테스트 커버리지
coverage/
**/coverage/
# 환경 변수 (보안)
.env
.env.*
**/.env
**/.env.*
# 패키지 매니저 lock 파일 (자동 생성)
pnpm-lock.yaml
package-lock.json
yarn.lock
# Expo / React Native 자동 생성 파일
apps/native/android/
apps/native/ios/
apps/native/.expo/
apps/native/expo-env.d.ts
# Next.js 자동 생성 파일
apps/web/next-env.d.ts
apps/docs/next-env.d.ts
# 정적 assets
**/public/
**/assets/
# 로그 및 디버그
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# OS / 에디터 메타파일
.DS_Store
*.pem
.vscode/